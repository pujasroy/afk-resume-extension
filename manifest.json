{
  "manifest_version": 3,
  "name": "AFK — Resume Instantly",
  "version": "2.1.0",
  "description": "Pick up exactly where your brain left off.",
  "permissions": ["tabs", "storage", "alarms", "idle"],
  "host_permissions": ["https://api.groq.com/*", "<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AFK — Resume Instantly"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
